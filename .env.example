# Discord bot token (from Discord Developer Portal)
DISCORD_TOKEN=your-discord-bot-token

# WeChat Work group bot webhook URL
# Format: https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key-here

# DeepL API key (Free or Pro — library auto-detects)
DEEPL_API_KEY=your-deepl-api-key
